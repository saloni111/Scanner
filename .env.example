# Copy this file to `.env` and fill in real values.

# ---- App ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Database ----
# Local docker-compose default. Override in production.
DATABASE_URL=postgresql+psycopg2://scanner:scanner@localhost:5432/scanner

# ---- LLM provider (OpenAI-compatible) ----
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---- GitHub integration ----
# Personal access token used to read PR diffs and post review comments.
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ---- Scanner limits ----
MAX_FILES_PER_SCAN=200
MAX_FILE_SIZE_KB=500
